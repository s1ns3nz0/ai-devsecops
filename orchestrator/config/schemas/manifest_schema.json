{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["product"],
  "properties": {
    "product": {
      "type": "object",
      "required": ["name", "description", "data_classification", "jurisdiction", "deployment"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "data_classification": {
          "type": "array",
          "items": { "type": "string" }
        },
        "jurisdiction": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deployment": {
          "type": "object",
          "required": ["cloud", "region"],
          "properties": {
            "cloud": { "type": "string" },
            "region": { "type": "string" },
            "compute": {
              "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "object" } }
              ]
            },
            "databases": {
              "type": "array",
              "items": { "type": "object" }
            },
            "storage": {
              "type": "array",
              "items": { "type": "object" }
            },
            "networking": {
              "type": "array",
              "items": { "type": "object" }
            },
            "messaging": {
              "type": "array",
              "items": { "type": "object" }
            },
            "observability": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        },
        "integrations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
